    :indicatorCode "6.1" ;
    skos:prefLabel "Rate of invasive alien species establishment"@en ;
    skos:prefLabel "Taux d’établissement des espèces exotiques envahissantes"@fr ;
    skos:prefLabel "Tasa de establecimiento de especies exóticas invasoras"@es ;
