kmgbf:indicator_A.4 a :Indicator ;
    :indicatorCode "A.4" ;
    skos:prefLabel "Proportion of populations within species with an effective population size greater than 500"@en ;
    skos:prefLabel "Pourcentage de populations au sein d’une espèce dont la taille effective est supérieure à 500 individus"@fr ;
    skos:prefLabel "Proporción de poblaciones dentro de especies con un tamaño de población efectivo mayor a 500"@es ;
    :isHeadlineFor kmgbf:goal_A, kmgbf:target_4 ;
    skos:inScheme kmgbf:indicatorScheme ;
    dct:source "https://www.cbd.int/doc/decisions/cop-16/cop-16-dec-31-en.pdf" .

kmgbf:indicator_B.1 a :Indicator ;
    :indicatorCode "B.1" ;
    skos:prefLabel "Services provided by ecosystems"@en ;
    skos:prefLabel "Services rendus par les écosystèmes"@fr ;
    skos:prefLabel "Servicios brindados por los ecosistemas"@es ;
    :isHeadlineFor kmgbf:goal_B, kmgbf:target_11 ;
    skos:inScheme kmgbf:indicatorScheme ;
    dct:source "https://www.cbd.int/doc/decisions/cop-16/cop-16-dec-31-en.pdf" .

kmgbf:indicator_B.b a :Indicator ;
    :indicatorCode "B.b" ;
    skos:prefLabel "Number of countries with policies or actions for implementing and monitoring the sustainable use of biodiversity and the maintenance and enhancement of nature's contributions to people, including ecosystem functions and services"@en ;
    skos:prefLabel "Nombre de pays disposant de politiques ou des mesures pour mettre en œuvre et surveiller l’utilisation durable de la biodiversité et la préservation et le renforcement des contributions de la nature à l’homme, y compris les fonctions et services écosystémiques"@fr ;
    skos:prefLabel "Número de países que cuentan con políticas o medidas para implementar y hacer un seguimiento de la utilización sostenible de la diversidad biológica y el mantenimiento y la mejora de las contribuciones de la naturaleza a las personas, incluidas las funciones y los servicios de los ecosistemas"@es ;
    :isBinaryFor kmgbf:goal_B ;
    skos:inScheme kmgbf:indicatorScheme ;
    dct:source "https://www.cbd.int/doc/decisions/cop-16/cop-16-dec-31-en.pdf" .

kmgbf:indicator_C.1 a :Indicator ;
    :indicatorCode "C.1" ;
    skos:prefLabel "Monetary benefits received in accordance with applicable internationally agreed access and benefit-sharing instruments"@en ;
    skos:prefLabel "Avantages monétaires reçus conformément aux instruments internationaux applicables en matière d’accès et de partage des avantages"@fr ;
    skos:prefLabel "Beneficios monetarios percibidos de conformidad con instrumentos aplicables de acceso y participación en los beneficios acordados internacionalmente"@es ;
    :isHeadlineFor kmgbf:goal_C, kmgbf:target_13 ;
    skos:inScheme kmgbf:indicatorScheme ;
    dct:source "https://www.cbd.int/doc/decisions/cop-16/cop-16-dec-31-en.pdf" .

kmgbf:indicator_C.2 a :Indicator ;
    :indicatorCode "C.2" ;
    skos:prefLabel "Non-monetary benefits arising from applicable international access and benefit-sharing instruments"@en ;
    skos:prefLabel "Avantages non monétaires découlant des instruments internationaux applicables en matière d’accès et de partage des avantages"@fr ;
    skos:prefLabel "Beneficios no monetarios derivados de instrumentos internacionales aplicables de acceso y participación en los beneficios"@es ;
    :isHeadlineFor kmgbf:goal_C, kmgbf:target_13 ;
    skos:inScheme kmgbf:indicatorScheme ;
    dct:source "https://www.cbd.int/doc/decisions/cop-16/cop-16-dec-31-en.pdf" .

kmgbf:indicator_13.b a :Indicator ;
    :indicatorCode "13.b" ;
    skos:prefLabel "Number of countries that have taken effective legal, policy, administrative and capacity-building measures at all levels, as appropriate, to ensure the fair and equitable sharing of benefits from the utilization of genetic resources and from digital sequence information on genetic resources, as well as traditional knowledge associated with genetic resources"@en ;
    skos:prefLabel "Nombre de pays qui ont pris des mesures juridiques, politiques, administratives et de renforcement des capacités efficaces à tous les niveaux, selon qu’il convient, pour assurer le partage juste et équitable des avantages découlant de l’utilisation des ressources génétiques et de l’information de séquençage numérique sur les ressources génétiques, ainsi que des connaissances traditionnelles associées aux ressources génétiques"@fr ;
    skos:prefLabel "Número de países que han adoptado medidas jurídicas, de políticas, administrativas y de creación de capacidad eficaces en todos los niveles, según proceda, tendientes a garantizar la participación justa y equitativa en los beneficios que se deriven de la utilización de los recursos genéticos y de la información digital sobre secuencias de recursos genéticos, así como de los conocimientos tradicionales asociados a los recursos genéticos"@es ;
    :isBinaryFor kmgbf:goal_C, kmgbf:target_13 ;
    skos:inScheme kmgbf:indicatorScheme ;
    dct:source "https://www.cbd.int/doc/decisions/cop-16/cop-16-dec-31-en.pdf" .

kmgbf:indicator_D.1 a :Indicator ;
    :indicatorCode "D.1" ;
    skos:prefLabel "International public funding, including official development assistance for conservation and sustainable use of biodiversity and ecosystems"@en ;
    skos:prefLabel "Financement public international, y compris l’aide publique au développement pour la conservation et l’utilisation durable de la biodiversité et des écosystèmes"@fr ;
    skos:prefLabel "Financiación pública internacional, incluida asistencia oficial para el desarrollo para la conservación y la utilización sostenible de la diversidad biológica y los ecosistemas"@es ;
    :isHeadlineFor kmgbf:goal_D, kmgbf:target_19 ;
    skos:inScheme kmgbf:indicatorScheme ;
    dct:source "https://www.cbd.int/doc/decisions/cop-16/cop-16-dec-31-en.pdf" .

kmgbf:indicator_D.2 a :Indicator ;
    :indicatorCode "D.2" ;
    skos:prefLabel "Domestic public funding on conservation and sustainable use of biodiversity and ecosystems"@en ;
    skos:prefLabel "Financement public national pour la conservation et l’utilisation durable de la biodiversité et des écosystèmes"@fr ;
    skos:prefLabel "Financiación pública nacional para la conservación y la utilización sostenible de la diversidad biológica y los ecosistemas"@es ;
    :isHeadlineFor kmgbf:goal_D, kmgbf:target_19 ;
    skos:inScheme kmgbf:indicatorScheme ;
    dct:source "https://www.cbd.int/doc/decisions/cop-16/cop-16-dec-31-en.pdf" .

kmgbf:indicator_D.3 a :Indicator ;
    :indicatorCode "D.3" ;
    skos:prefLabel "Private funding (domestic and international) on conservation and sustainable use of biodiversity and ecosystems"@en ;
    skos:prefLabel "Financement privé (national et international) pour la conservation et l’utilisation durable de la biodiversité et des écosystèmes"@fr ;
    skos:prefLabel "Financiación privada (nacional e internacional) para la conservación y la utilización sostenible de la diversidad biológica y los ecosistemas"@es ;
    :isHeadlineFor kmgbf:goal_D, kmgbf:target_19 ;
    skos:inScheme kmgbf:indicatorScheme ;
    dct:source "https://www.cbd.int/doc/decisions/cop-16/cop-16-dec-31-en.pdf" .

kmgbf:indicator_1.1 a :Indicator ;
    :indicatorCode "1.1" ;
    skos:prefLabel "Percentage of land and sea area covered by biodiversity-inclusive spatial plans"@en ;
    skos:prefLabel "Pourcentage de la surface terrestre et maritime faisant l’objet d’une planification spatiale respectueuse de la biodiversité"@fr ;
    skos:prefLabel "Porcentaje de superficie terrestre y marina cubierta por planes espaciales que tienen en cuenta la diversidad biológica"@es ;
    :isHeadlineFor kmgbf:target_1 ;
    skos:inScheme kmgbf:indicatorScheme ;
    dct:source "https://www.cbd.int/doc/decisions/cop-16/cop-16-dec-31-en.pdf" .

kmgbf:indicator_1.b a :Indicator ;
    :indicatorCode "1.b" ;
    skos:prefLabel "Number of countries using participatory, integrated and biodiversity-inclusive spatial planning and/or effective management processes addressing land- and sea-use change to bring the loss of areas of high biodiversity importance close to zero by 2030"@en ;
    skos:prefLabel "Nombre de pays disposant d’une planification spatiale participative, intégrée et respectueuse de la biodiversité ou de processus de gestion du changement d’affectation des terres et des mers efficaces, afin de réduire la perte de zones de grande importante pour la biodiversité à un niveau proche de zéro d’ici à 2030"@fr ;
    skos:prefLabel "Número de países que utilizan una planificación espacial participativa integrada que tiene en cuenta la diversidad biológica o procesos de gestión eficaces que abordan el cambio en el uso de la tierra y los océanos con el fin de que la pérdida de zonas de suma importancia para la diversidad biológica se acerque a cero para 2030"@es ;
    :isBinaryFor kmgbf:target_1 ;
    skos:inScheme kmgbf:indicatorScheme ;
    dct:source "https://www.cbd.int/doc/decisions/cop-16/cop-16-dec-31-en.pdf" .

kmgbf:indicator_2.1 a :Indicator ;
    :indicatorCode "2.1" ;
    skos:prefLabel "Area under restoration"@en ;
    skos:prefLabel "Zone en cours de restauration"@fr ;
    skos:prefLabel "Superficie sujeta a restauración"@es ;
    :isHeadlineFor kmgbf:target_2 ;
    skos:inScheme kmgbf:indicatorScheme ;
    dct:source "https://www.cbd.int/doc/decisions/cop-16/cop-16-dec-31-en.pdf" .

kmgbf:indicator_3.1 a :Indicator ;
    :indicatorCode "3.1" ;
    skos:prefLabel "Coverage of protected areas and other effective area-based conservation measures"@en ;
    skos:prefLabel "Couverture des zones protégées et autres mesures efficaces de conservation par zone"@fr ;
    skos:prefLabel "Cobertura de áreas protegidas y otras medidas de conservación eficaces basadas en áreas"@es ;
    :isHeadlineFor kmgbf:target_3 ;
    skos:inScheme kmgbf:indicatorScheme ;
    dct:source "https://www.cbd.int/doc/decisions/cop-16/cop-16-dec-31-en.pdf" .

kmgbf:indicator_5.1 a :Indicator ;
    :indicatorCode "5.1" ;
    skos:prefLabel "Proportion of fish stocks within biologically sustainable levels"@en ;
    skos:prefLabel "Pourcentage des stocks halieutiques se trouvant à des niveaux biologiquement viables"@fr ;
    skos:prefLabel "Proporción de poblaciones de peces cuyos niveles son biológicamente sostenibles"@es ;
    :isHeadlineFor kmgbf:target_5 ;
    skos:inScheme kmgbf:indicatorScheme ;
    dct:source "https://www.cbd.int/doc/decisions/cop-16/cop-16-dec-31-en.pdf" .

kmgbf:indicator_5.b a :Indicator ;
    :indicatorCode "5.b" ;
    skos:prefLabel "Number of countries with legal instruments or other policy frameworks for regulating trade in wild species"@en ;
    skos:prefLabel "Nombre de pays disposant d’instruments juridiques ou d’autres cadres politiques de réglementation du commerce des espèces sauvages"@fr ;
    skos:prefLabel "Número de países que cuentan con instrumentos jurídicos u otros marcos de políticas que regulan el comercio de especies silvestres"@es ;
    :isBinaryFor kmgbf:target_5 ;
    skos:inScheme kmgbf:indicatorScheme ;
    dct:source "https://www.cbd.int/doc/decisions/cop-16/cop-16-dec-31-en.pdf" .

