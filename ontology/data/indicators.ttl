@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

##############################################################################
# KMGBF Indicators (204 unique indicators)
#
# Generated from: REF/indicators-extracted.json (authoritative)
# Translations: REF/cop-16-dec-31-{fr,es}.docx via indicators-translations.csv
# Source: CBD/COP/DEC/16/31
#   Annex I: Headline and Binary indicators
#   Annex II: Component and Complementary indicators
#
# Role assignments (an indicator can have multiple roles):
#   :isHeadlineFor      - 28 headline assignments
#   :isBinaryFor        - 16 binary assignments
#   :isComponentFor     - 47 component assignments
#   :isComplementaryFor - 131 complementary assignments
##############################################################################

## All indicators share the same source ##
