kmgbf:indicator_A.4 a :Indicator ;
    :indicatorCode "A.4" ;
    skos:prefLabel "Proportion of populations within species with an effective population size greater than 500"@en ;
    skos:prefLabel "Pourcentage de populations au sein d’une espèce dont la taille effective est supérieure à 500 individus"@fr ;
    skos:prefLabel "Proporción de poblaciones dentro de especies con un tamaño de población efectivo mayor a 500"@es ;
    :isHeadlineFor kmgbf:goal_A, kmgbf:target_4 ;
