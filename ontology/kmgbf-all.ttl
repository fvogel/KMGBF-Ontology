    :isComplementaryFor kmgbf:target_22 ;
    skos:inScheme kmgbf:indicatorScheme .

kmgbf:indicator_23.CT.1 a :Indicator ;
    :indicatorCode "23.CT.1" ;
    skos:prefLabel "Proportion of seats held by women in (a) national parliaments and (b) local governments"@en ;
